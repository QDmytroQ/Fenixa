{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER_NAME;Database=FenixaDb;User Id=YOUR_USERNAME;Password=YOUR_PASSWORD;TrustServerCertificate=True;MultipleActiveResultSets=true;",
    "Redis": "localhost:6379,abortConnect=false"
  },


  "Jwt": {
    "Issuer": "FenixaService",
    "Audience": "FenixaClient"
  },
  "AccessToken": {
    "LifetimeMinutes": 15
  },

  "RefreshToken": {
    "LifetimeDays": 7
  },

  "Gemini": {
    "EncryptionKey": ""
  }
}
